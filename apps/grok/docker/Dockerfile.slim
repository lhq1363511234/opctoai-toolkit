# syntax=docker/dockerfile:1.7
FROM python:3.13-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    LANG=C.UTF-8 \
    LC_ALL=C.UTF-8 \
    DISPLAY=:99 \
    PORT=18425 \
    APP_HOME=/app

WORKDIR /app

# Minimal runtime for Xvfb + Chromium automation
RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
    curl \
    wget \
    gnupg \
    unzip \
    xvfb \
    fonts-liberation \
    fonts-noto-cjk \
    libasound2 \
    libatk-bridge2.0-0 \
    libatk1.0-0 \
    libcups2 \
    libdbus-1-3 \
    libdrm2 \
    libgbm1 \
    libgtk-3-0 \
    libnspr4 \
    libnss3 \
    libx11-xcb1 \
    libxcomposite1 \
    libxdamage1 \
    libxrandr2 \
    xdg-utils \
    chromium \
    chromium-driver \
 && rm -rf /var/lib/apt/lists/*

# Python deps only (no project venv copy)
COPY requirements.docker.txt /tmp/requirements.docker.txt
RUN pip install --no-cache-dir -r /tmp/requirements.docker.txt \
 && rm -f /tmp/requirements.docker.txt

# App source (filtered by .dockerignore)
COPY . /app

# Writable runtime dirs for accounts / cpa output
RUN mkdir -p /app/cpa_auths /app/data /data \
 && chmod +x /app/docker/entrypoint.sh

EXPOSE 18425

ENTRYPOINT ["/app/docker/entrypoint.sh"]
CMD ["web"]
