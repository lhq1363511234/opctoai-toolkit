# Required SMTP sender settings
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=service@example.com
SMTP_PASSWORD=replace-me
SMTP_FROM=service@example.com
SMTP_FROM_NAME=Mail Console

# Optional receive/send integrations
OPC_MAIL_BASE=https://mail.example.com
OPC_MAIL_DOMAINS=example.com
TELE_OPC_BASE=
TELE_OPC_DEV_TOKEN=

# Optional public providers (defaults already work if left empty)
# DUCKMAIL_BASE=https://api.duckmail.sbs
# MAILTM_BASE=https://api.mail.tm
# TEMPMAIL_BASE=https://api.internal.temp-mail.io/api/v3

# Cloudflare FreeMail (Workers + D1 + R2 + Email Routing)
FREEMAIL_BASE=https://your-mail-worker.example.workers.dev
FREEMAIL_API_KEY=replace-with-worker-jwt-token
